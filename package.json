{
  "name": "lingo-now",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @lingo-now/frontend dev",
    "dev:backend": "pnpm --filter @lingo-now/backend dev",
    "dev:frontend": "pnpm --filter @lingo-now/frontend dev",
    "dev:all": "pnpm --parallel --filter @lingo-now/frontend --filter @lingo-now/backend run dev",
    "build": "pnpm --filter @lingo-now/contracts build && pnpm --filter @lingo-now/backend cf-typegen && pnpm --filter @lingo-now/frontend build",
    "preview": "pnpm --filter @lingo-now/frontend preview",
    "test": "pnpm --filter @lingo-now/backend test && pnpm --filter @lingo-now/frontend test",
    "test:e2e": "pnpm --filter @lingo-now/frontend test:e2e",
    "test:e2e:ui": "pnpm --filter @lingo-now/frontend test:e2e:ui",
    "format": "pnpm --filter @lingo-now/frontend format",
    "lint": "pnpm --filter @lingo-now/frontend lint",
    "check": "pnpm --filter @lingo-now/frontend check",
    "deploy": "pnpm build",
    "deploy:backend": "pnpm --filter @lingo-now/backend deploy",
    "cf-typegen": "pnpm --filter @lingo-now/backend cf-typegen"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}