{
	"name": "@lingo-now/frontend",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:android": "LIVE_RELOAD=true pnpm exec cap run android",
