		"preview": "vite preview",
		"test": "vitest run --passWithNoTests",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"format": "biome format .",
		"lint": "biome lint .",
		"check": "biome check ."
	},
